{
  "prefix": "core",
  "components": [
    {
      "selector": "core-button",
      "inputs": [
        { "name": "variant", "required": true, "values": ["primary", "secondary", "ghost"] },
        { "name": "size", "required": false, "values": ["sm", "md", "lg"] },
        { "name": "disabled", "required": false }
      ],
      "deprecated": false
    },
    {
      "selector": "core-card-legacy",
      "deprecated": true,
      "replacement": "core-card"
    },
    {
      "selector": "core-card",
      "inputs": [
        { "name": "title", "required": false },
        { "name": "elevated", "required": false }
      ],
      "deprecated": false
    },
    {
      "selector": "core-spinner",
      "inputs": [
        { "name": "size", "required": false, "values": ["sm", "md", "lg"] }
      ],
      "deprecated": false
    },
    {
      "selector": "core-input",
      "inputs": [
        { "name": "label", "required": true },
        { "name": "placeholder", "required": false },
        { "name": "disabled", "required": false }
      ],
      "deprecated": false
    },
    {
      "selector": "core-modal",
      "inputs": [
        { "name": "title", "required": true },
        { "name": "isOpen", "required": true }
      ],
      "deprecated": false
    }
  ],
  "knownSelectors": [
    "core-button", "core-card", "core-spinner",
    "core-input", "core-modal", "core-badge",
    "core-tooltip", "core-table", "core-icon"
  ],
  "cssRules": {
    "blockGlobalOverrides": true,
    "blockNgDeep": true
  }
}
