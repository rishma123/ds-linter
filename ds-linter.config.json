{
  "prefix": "my-ds",
  "components": [
    {
      "selector": "my-ds-button",
      "inputs": [
        { "name": "variant", "required": true, "values": ["primary", "secondary", "ghost"] },
        { "name": "size", "required": false, "values": ["sm", "md", "lg"] },
        { "name": "disabled", "required": false }
      ],
      "deprecated": false
    },
    {
      "selector": "my-ds-card-legacy",
      "deprecated": true,
      "replacement": "my-ds-card"
    },
    {
      "selector": "my-ds-card",
      "inputs": [
        { "name": "title", "required": false },
        { "name": "elevated", "required": false }
      ],
      "deprecated": false
    },
    {
      "selector": "my-ds-spinner",
      "inputs": [
        { "name": "size", "required": false, "values": ["sm", "md", "lg"] }
      ],
      "deprecated": false
    },
    {
      "selector": "my-ds-input",
      "inputs": [
        { "name": "label", "required": true },
        { "name": "placeholder", "required": false },
        { "name": "disabled", "required": false }
      ],
      "deprecated": false
    },
    {
      "selector": "my-ds-modal",
      "inputs": [
        { "name": "title", "required": true },
        { "name": "isOpen", "required": true }
      ],
      "deprecated": false
    }
  ],
  "knownSelectors": [
    "my-ds-button", "my-ds-card", "my-ds-spinner",
    "my-ds-input", "my-ds-modal", "my-ds-badge",
    "my-ds-tooltip", "my-ds-table", "my-ds-icon"
  ],
  "cssRules": {
    "blockGlobalOverrides": true,
    "blockNgDeep": true
  }
}
